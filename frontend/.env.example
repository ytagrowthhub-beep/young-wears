# --- Local dev (frontend/.env.local) ---
# Browser API base (optional). If unset, requests use same-origin /api/backend → BACKEND_URL on the server.
NEXT_PUBLIC_API_URL=http://localhost:5000/api
BACKEND_URL=http://127.0.0.1:5000

# Supabase (Auth). URL must be https://YOUR_REF.supabase.co — no double "https://".
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Or only ref (URL is derived): NEXT_PUBLIC_SUPABASE_PROJECT_REF=your_ref_here

NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Or JWT anon key from Supabase Dashboard → Settings → API:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — profile “Delete account” (never expose publicly):
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# --- Vercel ---
# Add the same NEXT_PUBLIC_* Supabase vars in Project → Settings → Environment Variables.
# Use Production + Preview as needed. Set NEXT_PUBLIC_SITE_URL to https://your-app.vercel.app (no trailing slash ok).
# Redeploy after saving env vars so the Next.js build embeds them.
