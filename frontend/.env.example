# --- Catalog API ---
# Default: same-origin Next routes (/api/products). Leave NEXT_PUBLIC_API_URL unset on Vercel.
# Legacy Express catalog only:
# NEXT_PUBLIC_API_URL=http://localhost:5000/api
# BACKEND_URL=http://127.0.0.1:5000

# --- Supabase (Auth + Postgres catalog) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_PROJECT_REF=your_ref_here

NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — profile “Delete account”:
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# Server-only — POST /api/admin/seed-catalog (run once after SQL migration), header x-young-wears-seed-secret:
# SEED_CATALOG_SECRET=long_random_string

# --- Vercel ---
# Set NEXT_PUBLIC_* + SUPABASE_SERVICE_ROLE_KEY + SEED_CATALOG_SECRET, redeploy, then call seed POST once.
