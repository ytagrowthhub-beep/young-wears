{
  "name": "young_wears",
  "version": "1.0.0",
  "private": true,
  "description": "Young Wears monorepo — frontend (Next.js), backend (Express)",
  "scripts": {
    "start": "npm --prefix frontend run dev",
    "dev": "npm --prefix frontend run dev",
